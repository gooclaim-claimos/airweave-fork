# Production build for the Gooclaim Sources surface (sources.dev.gooclaim.com).
# Read by Vite at build time and baked into the bundle. Toggles the rebrand
# work shipped in specs 01–07 under
# tasks/Review-Task/Gooclaim-Airweave-Sources/Frontend/ — sidebar wordmark,
# nav gating, Airweave→Gooclaim OS text sweep, empty-state welcome, onboarding
# skip, billing redirects, etc. Without this flag the bundle renders as
# upstream Airweave.
VITE_GOOCLAIM_MODE=true
